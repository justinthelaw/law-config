#!/usr/bin/env bash
#
# clean-codex - Remove local Codex session history/state while preserving
# preferences, rules, auth, and configuration.
#
# Usage:
#   clean-codex [--dry-run] [--yes] [--force] [codex_home]
#
# Examples:
#   clean-codex --dry-run
#   clean-codex --yes

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: clean-codex [options] [codex_home]

Deletes local Codex session/state artifacts while preserving durable config.
Prunes prompt history from .codex-global-state.json while preserving preferences.
Preserves: auth.json, config.toml, .codex-global-state.json, memories/,
skills/, plugins/, .tmp/plugins/, version.json.

Options:
  -n, --dry-run         Show what would be removed without deleting anything.
  -y, --yes             Skip the confirmation prompt.
  -f, --force           Run even if Codex appears to be running.
  -h, --help            Show this help text.

Arguments:
  codex_home            Override the Codex data directory.
                        Default: $CODEX_HOME or ~/.codex
EOF
}

DRY_RUN=0
SKIP_CONFIRM=0
FORCE=0
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
CODEX_HOME_ARG_SET=0

while [[ $# -gt 0 ]]; do
  case "$1" in
  -n | --dry-run)
    DRY_RUN=1
    ;;
  -y | --yes)
    SKIP_CONFIRM=1
    ;;
  -f | --force)
    FORCE=1
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  -*)
    echo "Unknown option: $1" >&2
    usage >&2
    exit 1
    ;;
  *)
    if [[ "$CODEX_HOME_ARG_SET" -eq 1 ]]; then
      echo "Only one codex_home argument is supported." >&2
      usage >&2
      exit 1
    fi
    CODEX_HOME="$1"
    CODEX_HOME_ARG_SET=1
    ;;
  esac
  shift
done

CODEX_HOME="${CODEX_HOME%/}"

if [[ ! -d "$CODEX_HOME" ]]; then
  echo "Codex home not found: $CODEX_HOME" >&2
  exit 1
fi

running_codex_processes() {
  ps -eo pid=,command= 2>/dev/null | awk -v self="$$" '
        function base(path, parts_count, parts) {
            parts_count = split(path, parts, "/")
            return parts[parts_count]
        }

        {
            pid = $1
            $1 = ""
            sub(/^[[:space:]]+/, "", $0)
            cmd = $0

            argc = split(cmd, argv, /[[:space:]]+/)
            is_codex_binary = 0
            is_codex_js = 0
            is_codex_package = 0
            is_codex_sandbox = 0

            for (i = 1; i <= argc; i++) {
                token = argv[i]
                token_base = base(token)

                if (token_base == "codex") {
                    is_codex_binary = 1
                }

                if (token_base == "codex.js") {
                    is_codex_js = 1
                }

                if (token ~ /^@openai\/codex(@|$)/) {
                    is_codex_package = 1
                }

                if (token_base ~ /^codex(-[^[:space:]]+)?-sandbox$/) {
                    is_codex_sandbox = 1
                }
            }

            if (pid == self) {
                next
            }

            if (is_codex_binary || is_codex_js || is_codex_package || is_codex_sandbox) {
                print pid " " cmd
            }
        }
    '
}

format_kib() {
  local kib="$1"

  awk -v kib="$kib" '
        BEGIN {
            if (kib >= 1048576) {
                printf "%.2f GiB", kib / 1048576
            } else if (kib >= 1024) {
                printf "%.2f MiB", kib / 1024
            } else {
                printf "%d KiB", kib
            }
        }
    '
}

if [[ "$FORCE" -ne 1 ]]; then
  running="$(running_codex_processes)"
  if [[ -n "$running" ]]; then
    echo "Codex appears to still be running. Close it before cleaning local session data." >&2
    echo "$running" >&2
    echo "Re-run with --force if you want to bypass this check." >&2
    exit 1
  fi
fi

static_targets=(
  "history.jsonl"
  "session_index.jsonl"
  "shell_snapshots"
  "tmp"
  "log"
  "ambient-suggestions"
)

glob_targets=(
  "logs_*.sqlite"
  "logs_*.sqlite-shm"
  "logs_*.sqlite-wal"
  "state_*.sqlite"
  "state_*.sqlite-shm"
  "state_*.sqlite-wal"
)

cache_targets=(
  ".tmp/app-server-remote-plugin-sync-v1"
  ".tmp/plugins.sha"
  "cache/codex_apps_tools"
  "cloud-requirements-cache.json"
  "models_cache.json"
)

declare -a targets=()
declare -a archived_session_targets=()
archived_session_target_count=0

add_target() {
  local path="$1"

  if [[ -e "$path" ]]; then
    targets+=("$path")
  fi
}

add_archived_session_targets() {
  local archived_dir="${CODEX_HOME}/archived_sessions"

  if [[ -d "$archived_dir" ]]; then
    while IFS= read -r archived_path; do
      archived_session_targets+=("$archived_path")
      archived_session_target_count=$((archived_session_target_count + 1))
    done < <(find "$archived_dir" -mindepth 1 -maxdepth 1 2>/dev/null | sort)
  fi
}

for rel_path in "${static_targets[@]}"; do
  add_target "${CODEX_HOME}/${rel_path}"
done

for rel_path in "${cache_targets[@]}"; do
  add_target "${CODEX_HOME}/${rel_path}"
done

add_archived_session_targets

shopt -s nullglob
for pattern in "${glob_targets[@]}"; do
  while IFS= read -r match; do
    targets+=("$match")
  done < <(compgen -G "$CODEX_HOME/$pattern" || true)
done
shopt -u nullglob

global_state_path="${CODEX_HOME}/.codex-global-state.json"
global_state_has_prompt_history=0
if [[ -f "$global_state_path" ]] && grep -q '"prompt-history"' "$global_state_path"; then
  global_state_has_prompt_history=1
fi

if [[ "${#targets[@]}" -eq 0 && "$archived_session_target_count" -eq 0 && "$global_state_has_prompt_history" -eq 0 ]]; then
  echo "No Codex session data found under $CODEX_HOME."
  exit 0
fi

estimated_kib=0
for path in "${targets[@]}"; do
  path_kib="$(du -sk "$path" 2>/dev/null | awk '{print $1}')"
  estimated_kib="$((estimated_kib + ${path_kib:-0}))"
done
if [[ "$archived_session_target_count" -gt 0 ]]; then
  for path in "${archived_session_targets[@]}"; do
    path_kib="$(du -sk "$path" 2>/dev/null | awk '{print $1}')"
    estimated_kib="$((estimated_kib + ${path_kib:-0}))"
  done
fi

echo "Codex home: $CODEX_HOME"
if [[ "${#targets[@]}" -gt 0 ]]; then
  echo "Removing the following paths:"
  for path in "${targets[@]}"; do
    echo "  $path"
  done
fi
if [[ "$archived_session_target_count" -gt 0 ]]; then
  echo "Removing archived thread files:"
  for path in "${archived_session_targets[@]}"; do
    echo "  $path"
  done
fi
if [[ "$global_state_has_prompt_history" -eq 1 ]]; then
  echo "Pruning prompt history from:"
  echo "  $global_state_path"
fi
echo "Estimated reclaimable space: $(format_kib "$estimated_kib")"
echo "Runtime caches are included in the default cleanup."
echo "Preserving active threads in sessions/, Codex memories in memories/, and installed plugin caches under plugins/ and .tmp/plugins/."

if [[ "$DRY_RUN" -eq 1 ]]; then
  exit 0
fi

if [[ "$global_state_has_prompt_history" -eq 1 ]] && ! command -v jq >/dev/null 2>&1; then
  echo "Unable to prune prompt history from .codex-global-state.json: jq not found." >&2
  exit 1
fi

if [[ "$SKIP_CONFIRM" -ne 1 ]]; then
  printf 'Delete these Codex session artifacts? [y/N] '
  read -r response
  case "$response" in
  [Yy] | [Yy][Ee][Ss]) ;;
  *)
    echo "Aborted."
    exit 1
    ;;
  esac
fi

for path in "${targets[@]}"; do
  rm -rf -- "$path"
done

if [[ "$archived_session_target_count" -gt 0 ]]; then
  for path in "${archived_session_targets[@]}"; do
    rm -rf -- "$path"
  done
fi

if [[ "$global_state_has_prompt_history" -eq 1 ]]; then
  global_state_tmp="${global_state_path}.tmp.$$"
  if ! jq 'del(."electron-persisted-atom-state"."prompt-history")' "$global_state_path" >"$global_state_tmp"; then
    rm -f -- "$global_state_tmp"
    echo "Unable to prune prompt history from .codex-global-state.json." >&2
    exit 1
  fi
  mv "$global_state_tmp" "$global_state_path"
fi

echo "Codex session data removed."
echo "Preserved: active threads in sessions/, auth.json, config.toml, .codex-global-state.json, memories/, skills/, plugins/, .tmp/plugins/, version.json."
