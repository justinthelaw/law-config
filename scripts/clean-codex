#!/usr/bin/env bash
#
# clean-codex - Remove orphaned/deleted Codex thread state and disposable
# runtime caches without separating live rollout files from their registry.
#
# Usage:
#   clean-codex [--dry-run] [--yes] [--force] [codex_home]

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: clean-codex [options] [codex_home]

Prunes deleted and orphaned Codex thread state while preserving registered
threads, their rollout JSONL files, shell snapshots, indexes, and SQLite rows.
Related rows in state, logs, goals, and memory databases are reconciled to the
same surviving thread set. Disposable runtime caches are also removed when not
in active use.

Preserves: auth.json, config.toml, live sessions/, state databases, supported
memories/, skills/, plugins/, .tmp/plugins/, .tmp/bundled-marketplaces/,
.tmp/marketplaces/, and version.json.

Options:
  -n, --dry-run         Show what would be removed without deleting anything.
  -y, --yes             Skip the confirmation prompt.
  -f, --force           Allow WAL-safe cleanup while Codex is running.
  -h, --help            Show this help text.

Arguments:
  codex_home            Override the Codex data directory.
                        Default: $CODEX_HOME or ~/.codex

Environment:
  CLEAN_CODEX_GRACE_MINUTES
                        Minimum inactivity window for unregistered artifacts.
                        Default: 15
EOF
}

DRY_RUN=0
SKIP_CONFIRM=0
FORCE=0
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
CODEX_HOME_ARG_SET=0
GRACE_MINUTES="${CLEAN_CODEX_GRACE_MINUTES:-15}"

while [[ $# -gt 0 ]]; do
  case "$1" in
  -n | --dry-run)
    DRY_RUN=1
    ;;
  -y | --yes)
    SKIP_CONFIRM=1
    ;;
  -f | --force)
    FORCE=1
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  -*)
    echo "Unknown option: $1" >&2
    usage >&2
    exit 1
    ;;
  *)
    if [[ "$CODEX_HOME_ARG_SET" -eq 1 ]]; then
      echo "Only one codex_home argument is supported." >&2
      usage >&2
      exit 1
    fi
    CODEX_HOME="$1"
    CODEX_HOME_ARG_SET=1
    ;;
  esac
  shift
done

CODEX_HOME="${CODEX_HOME%/}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
STATE_CLEANER="${SCRIPT_DIR}/clean-codex-state.py"

if [[ ! -d "$CODEX_HOME" ]]; then
  echo "Codex home not found: $CODEX_HOME" >&2
  exit 1
fi

if [[ ! "$GRACE_MINUTES" =~ ^[0-9]+$ ]]; then
  echo "CLEAN_CODEX_GRACE_MINUTES must be a non-negative integer." >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required for referentially consistent Codex cleanup." >&2
  exit 1
fi

if [[ ! -f "$STATE_CLEANER" ]]; then
  echo "Missing state cleanup helper: $STATE_CLEANER" >&2
  exit 1
fi

running_codex_processes() {
  ps -eo pid=,command= 2>/dev/null | awk -v self="$$" '
        function base(path, parts_count, parts) {
            parts_count = split(path, parts, "/")
            return parts[parts_count]
        }

        {
            pid = $1
            $1 = ""
            sub(/^[[:space:]]+/, "", $0)
            cmd = $0

            argc = split(cmd, argv, /[[:space:]]+/)
            is_codex_binary = 0
            is_codex_js = 0
            is_codex_package = 0
            is_codex_sandbox = 0

            for (i = 1; i <= argc; i++) {
                token = argv[i]
                token_base = base(token)

                if (token_base == "codex") {
                    is_codex_binary = 1
                }

                if (token_base == "codex.js") {
                    is_codex_js = 1
                }

                if (token ~ /^@openai\/codex(@|$)/) {
                    is_codex_package = 1
                }

                if (token_base ~ /^codex(-[^[:space:]]+)?-sandbox$/) {
                    is_codex_sandbox = 1
                }
            }

            if (pid == self) {
                next
            }

            if (is_codex_binary || is_codex_js || is_codex_package || is_codex_sandbox) {
                print pid " " cmd
            }
        }
    '
}

format_kib() {
  local kib="$1"

  awk -v kib="$kib" '
        BEGIN {
            if (kib >= 1048576) {
                printf "%.2f GiB", kib / 1048576
            } else if (kib >= 1024) {
                printf "%.2f MiB", kib / 1024
            } else {
                printf "%d KiB", kib
            }
        }
    '
}

codex_running=0
process_detection_available=1
if running="$(running_codex_processes)"; then
  if [[ -n "$running" ]]; then
    codex_running=1
    if [[ "$FORCE" -ne 1 ]]; then
      echo "Codex appears to still be running. Close it before cleaning local session data." >&2
      echo "$running" >&2
      echo "Re-run with --force for WAL-safe live cleanup." >&2
      exit 1
    fi
  fi
else
  process_detection_available=0
  if [[ "$FORCE" -ne 1 ]]; then
    echo "Unable to determine whether Codex is running; refusing unsafe cleanup." >&2
    echo "Re-run with --force to assume Codex is live and use conservative cleanup." >&2
    exit 1
  fi
  codex_running=1
fi

volatile_targets=(
  "tmp"
  "log"
  "ambient-suggestions"
)

cache_targets=(
  ".tmp/app-server-remote-plugin-sync-v1"
  ".tmp/plugins.sha"
  ".tmp/plugin-share-local-paths-v1.json"
  ".tmp/legacy-primary-runtime-skills"
  "cache/codex_apps_tools"
  "cloud-requirements-cache.json"
  "models_cache.json"
)

cleanup_glob_targets=(
  ".tmp/plugins-backup-*"
  ".codex-global-state.json*.tmp-*"
  "..codex-global-state.json*.tmp-*"
)

declare -a targets=()
declare -a skipped_volatile_targets=()
target_count=0
skipped_volatile_target_count=0

add_target() {
  local path="$1"
  if [[ -e "$path" || -L "$path" ]]; then
    targets+=("$path")
    target_count=$((target_count + 1))
  fi
}

for rel_path in "${cache_targets[@]}"; do
  add_target "${CODEX_HOME}/${rel_path}"
done

for rel_path in "${volatile_targets[@]}"; do
  path="${CODEX_HOME}/${rel_path}"
  if [[ "$codex_running" -eq 1 ]]; then
    if [[ -e "$path" || -L "$path" ]]; then
      skipped_volatile_targets+=("$path")
      skipped_volatile_target_count=$((skipped_volatile_target_count + 1))
    fi
  else
    add_target "$path"
  fi
done

shopt -s nullglob
for pattern in "${cleanup_glob_targets[@]}"; do
  while IFS= read -r match; do
    add_target "$match"
  done < <(compgen -G "$CODEX_HOME/$pattern" || true)
done
shopt -u nullglob

estimated_kib=0
if [[ "$target_count" -gt 0 ]]; then
  for path in "${targets[@]}"; do
    path_kib="$(du -sk "$path" 2>/dev/null | awk '{print $1}')"
    estimated_kib="$((estimated_kib + ${path_kib:-0}))"
  done
fi

echo "Codex home: $CODEX_HOME"
if [[ "$codex_running" -eq 1 ]]; then
  echo "Codex is running: using SQLite transactions and a ${GRACE_MINUTES}-minute registration grace window."
  if [[ "$process_detection_available" -eq 0 ]]; then
    echo "Process detection was unavailable, so volatile runtime paths will be preserved."
  fi
fi
python3 "$STATE_CLEANER" --dry-run --grace-minutes "$GRACE_MINUTES" "$CODEX_HOME"

if [[ "$target_count" -gt 0 ]]; then
  echo "Disposable cache paths:"
  for path in "${targets[@]}"; do
    echo "  $path"
  done
  echo "Estimated cache space: $(format_kib "$estimated_kib")"
fi

if [[ "$skipped_volatile_target_count" -gt 0 ]]; then
  echo "Preserving volatile paths while Codex is running:"
  for path in "${skipped_volatile_targets[@]}"; do
    echo "  $path"
  done
fi

echo "Live thread rollouts, state rows, indexes, and shell snapshots are preserved as one consistency set."

if [[ "$DRY_RUN" -eq 1 ]]; then
  exit 0
fi

if [[ "$SKIP_CONFIRM" -ne 1 ]]; then
  printf 'Apply this Codex cleanup? [y/N] '
  read -r response
  case "$response" in
  [Yy] | [Yy][Ee][Ss]) ;;
  *)
    echo "Aborted."
    exit 1
    ;;
  esac
fi

python3 "$STATE_CLEANER" --apply --grace-minutes "$GRACE_MINUTES" "$CODEX_HOME"

path_has_open_handles() {
  local path="$1"

  if ! command -v lsof >/dev/null 2>&1; then
    return 2
  fi

  if [[ -d "$path" ]]; then
    lsof +D "$path" >/dev/null 2>&1
  else
    lsof "$path" >/dev/null 2>&1
  fi
}

removed_cache_count=0
if [[ "$target_count" -gt 0 ]]; then
  for path in "${targets[@]}"; do
    if [[ ! -e "$path" && ! -L "$path" ]]; then
      continue
    fi

    if path_has_open_handles "$path"; then
      echo "Preserving open cache path: $path"
      continue
    else
      lsof_status=$?
    fi

    if [[ "$lsof_status" -eq 2 && "$codex_running" -eq 1 ]]; then
      echo "Preserving cache path because lsof is unavailable while Codex is running: $path"
      continue
    fi

    rm -rf -- "$path"
    removed_cache_count=$((removed_cache_count + 1))
  done
fi

echo "Codex cleanup completed; removed ${removed_cache_count} disposable cache paths."
echo "Preserved: registered sessions and their SQLite/index/snapshot state, auth.json, config.toml, supported memories/, skills/, and installed plugin caches."
