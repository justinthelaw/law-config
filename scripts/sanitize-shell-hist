#!/usr/bin/env bash
#
# sanitize_shell_history.sh - Safely sanitize your Bash or Zsh history.
# Usage: ./sanitize_shell_history.sh <history_file>
# Example: ./sanitize_shell_history.sh ~/.zsh_history

set -euo pipefail

# Set locale to handle non-UTF-8 characters properly on macOS
export LC_ALL=C
export LANG=C

# Cleanup function
cleanup() {
  if [[ -n "${TMP_FILE:-}" ]]; then
    rm -f "$TMP_FILE" "${TMP_FILE}.new"
  fi
}
trap cleanup EXIT

# === Configuration ===
SENSITIVE_PATTERNS=(
  "password"
  "PASSWORD"
  "secret"
  "SECRET"
  "token"
  "TOKEN"
  "apikey"
  "APIKEY"
  "authorization"
  "AUTHORIZATION"
  "session"
  "SESSION"
  "arn:aws"
  "ARN:AWS"
)
# Patterns of failed/incorrect commands (expand as needed)
FAILED_PATTERNS=(
  "command not found"
  "No such file or directory"
  "syntax error"
  "not recognized as"
  "is not a function"
  "zsh:.*not found"
  "bash:.*not found"
)

# === Args and setup ===
if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <history_file>"
  exit 1
fi
HIST_FILE="$1"
# Create temp file with proper cross-platform support
if [[ "$OSTYPE" == "darwin"* ]]; then
  # macOS mktemp
  TMP_FILE="$(mktemp -t sanitize_hist)"
else
  # Linux mktemp
  TMP_FILE="$(mktemp)"
fi

echo "[*] Sanitizing: $HIST_FILE ..."

grep_filter() {
  local output_file="$1"
  local status
  shift

  if "$@" >"$output_file"; then
    return 0
  fi

  status=$?
  if [[ "$status" -eq 1 ]]; then
    return 0
  fi
  return "$status"
}

backup_history() {
  local epoch
  local candidate
  local counter=0

  epoch="$(date +%s)"
  candidate="${HIST_FILE}.bak.${epoch}"
  while [[ -e "$candidate" ]]; do
    counter=$((counter + 1))
    candidate="${HIST_FILE}.bak.${epoch}.$$.$counter"
  done

  BACKUP_FILE="$candidate"
  cp "$HIST_FILE" "$BACKUP_FILE"
}

# === Step 1: Normalize (remove timestamps, extra spaces) ===
normalize_history() {
  # Handles Zsh extended history lines with timestamps, strips them
  # Zsh extended: ': 1651737463:0;command here'
  # Use LC_ALL=C to handle binary/non-UTF-8 characters
  if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS (BSD sed) - use basic regex to avoid encoding issues
    LC_ALL=C sed 's/^: [0-9][0-9]*:[0-9][0-9]*;//' "$1" | LC_ALL=C sed 's/^[ 	]*//;s/[ 	]*$//'
  else
    # Linux (GNU sed)
    sed -E 's/^: [0-9]+:[0-9]+;//' "$1" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
  fi
}

# === Step 2: Remove sensitive lines ===
remove_sensitive() {
  local f="$1"
  local pattern
  cp "$f" "$TMP_FILE"
  for pattern in "${SENSITIVE_PATTERNS[@]}"; do
    # Remove any lines containing the pattern (case-insensitive)
    # Use LC_ALL=C for macOS to handle encoding issues
    if [[ "$OSTYPE" == "darwin"* ]]; then
      # macOS grep - use LC_ALL=C
      grep_filter "${TMP_FILE}.new" env LC_ALL=C grep -v -i "$pattern" "$TMP_FILE"
    else
      # Linux grep
      grep_filter "${TMP_FILE}.new" grep -vi "$pattern" "$TMP_FILE"
    fi
    mv "${TMP_FILE}.new" "$TMP_FILE"
  done
  mv "$TMP_FILE" "$f"
}

# === Step 3: Remove failed/incorrect commands ===
remove_failed() {
  local f="$1"
  local pattern
  cp "$f" "$TMP_FILE"
  for pattern in "${FAILED_PATTERNS[@]}"; do
    # Use LC_ALL=C for macOS to handle encoding issues
    if [[ "$OSTYPE" == "darwin"* ]]; then
      # macOS grep - use LC_ALL=C and basic regex
      grep_filter "${TMP_FILE}.new" env LC_ALL=C grep -v "$pattern" "$TMP_FILE"
    else
      # Linux grep - can use extended regex
      grep_filter "${TMP_FILE}.new" grep -Ev "$pattern" "$TMP_FILE"
    fi
    mv "${TMP_FILE}.new" "$TMP_FILE"
  done
  mv "$TMP_FILE" "$f"
}

# === Step 3b: Remove commands ending with multiple semicolons ===
remove_multi_semicolon() {
  local f="$1"
  # Removes lines ending with two or more semicolons and nothing after
  grep_filter "$TMP_FILE" env LC_ALL=C grep -Ev ';{2,}[[:space:]]*$' "$f"
  mv "$TMP_FILE" "$f"
}

# === Step 4: Remove empty and whitespace lines ===
remove_empty() {
  local f="$1"
  if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS - use LC_ALL=C and simpler pattern
    grep_filter "$TMP_FILE" env LC_ALL=C grep -v '^[ 	]*$' "$f"
  else
    # Linux
    grep_filter "$TMP_FILE" grep -v '^[[:space:]]*$' "$f"
  fi
  mv "$TMP_FILE" "$f"
}

# === Step 5: Deduplicate (keep last occurrence of each command) ===
dedupe_history() {
  # Keep the final copy of a command at the position where it last appeared.
  awk '{lines[NR]=$0; last[$0]=NR} END{for(i=1;i<=NR;i++)if(last[lines[i]]==i)print lines[i]}' "$1" >"$TMP_FILE"
  mv "$TMP_FILE" "$1"
}

# === Pipeline ===
backup_history
normalize_history "$HIST_FILE" >"$TMP_FILE"
mv "$TMP_FILE" "$HIST_FILE"
remove_sensitive "$HIST_FILE"
remove_failed "$HIST_FILE"
remove_multi_semicolon "$HIST_FILE"
remove_empty "$HIST_FILE"
dedupe_history "$HIST_FILE"

echo "[+] Done. Backup: $BACKUP_FILE"
